# Copy to Railway variables (or local .env for dev)
# Restart the service after changing variables.

NODE_ENV=production
PORT=5000

# -----------------------------------------------------------------------------
# Supabase (service role — server only, never expose to the app)
# Dashboard → Project Settings → API
# -----------------------------------------------------------------------------
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# -----------------------------------------------------------------------------
# Razorpay Checkout — store + session payments
# Dashboard → Account & Settings → API Keys
# -----------------------------------------------------------------------------
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
# Webhook secret for POST /api/webhooks/razorpay (event: payment.captured)
RAZORPAY_WEBHOOK_SECRET=

# -----------------------------------------------------------------------------
# RazorpayX — seller/practitioner payouts (optional)
# Can reuse RAZORPAY_KEY_ID / RAZORPAY_KEY_SECRET on the same account
# -----------------------------------------------------------------------------
RAZORPAYX_KEY_ID=
RAZORPAYX_KEY_SECRET=
RAZORPAYX_WEBHOOK_SECRET=
RAZORPAYX_ACCOUNT_NUMBER=
RAZORPAYX_FUND_ACCOUNT_ID=
RAZORPAYX_PAYOUT_MODE=IMPS

# Dev only — auto-complete payouts without RazorpayX (never true in production)
PAYOUT_DEV_AUTO_COMPLETE=false

# -----------------------------------------------------------------------------
# CORS — comma-separated origins for your Expo/web app
# Example: https://your-app.expo.dev,exp://localhost:8081
# -----------------------------------------------------------------------------
CORS_ALLOWED_ORIGINS=

# Optional: single app domain (also added to CORS allowlist)
# EXPO_PUBLIC_DOMAIN=your-app.example.com

# -----------------------------------------------------------------------------
# Email (optional — skipped without RESEND_API_KEY or SMTP)
# -----------------------------------------------------------------------------
EMAIL_PROVIDER=resend
RESEND_API_KEY=
EMAIL_FROM=Nature's Grace <noreply@yourdomain.com>

# Or raw SMTP
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=

# -----------------------------------------------------------------------------
# Push notifications (optional — Expo push API)
# -----------------------------------------------------------------------------
EXPO_ACCESS_TOKEN=
